<?xml version="1.0" encoding="utf-8"?>

<log4net>
    <!-- 控制台日志配置 -->
    <appender name="Console" type="log4net.Appender.ConsoleAppender">
        <!-- 日志输出格式 -->
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %5level [%thread] (%file:%line) - %message%newline" />
        </layout>
    </appender>
    <!-- 文件存储日志配置 -->
    <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
        <!-- 保存文件的名称 -->
        <file value="logs\WebApi.log" />
        <appendToFile value="true" />
        <!-- 文件的编码方式 -->
        <param name="Encoding" value="UTF-8" />
        <!-- 每个文件的大小 -->
        <maximumFileSize value="100MB" />
        <!-- 保存文件数量 -->
        <maxSizeRollBackups value="20" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <!-- 日志输出格式 -->
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>

    <logger name="12345678900001" additivity="false">
        <level value="ALL" />
        <appender-ref ref="12345678900001" />
    </logger>
    <appender name="12345678900001" type="log4net.Appender.RollingFileAppender">
        <param name="File" value="logs\Charger\" />
        <param name="AppendToFile" value="true" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <Encoding value="UTF-8" />
        <param name="StaticLogFileName" value="false" />
        <param name="RollingStyle" value="Composite" />
        <param name="DatePattern" value="yyyyMMdd/HH&quot;12345678900001.log&quot;" />
        <param name="maximumFileSize" value="200MB" />
        <param name="MaxSizeRollBackups" value="5" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>
    <logger name="12345678900002" additivity="false">
        <level value="ALL" />
        <appender-ref ref="12345678900002" />
    </logger>
    <appender name="12345678900002" type="log4net.Appender.RollingFileAppender">
        <param name="File" value="logs\Charger\" />
        <param name="AppendToFile" value="true" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <Encoding value="UTF-8" />
        <param name="StaticLogFileName" value="false" />
        <param name="RollingStyle" value="Composite" />
        <param name="DatePattern" value="yyyyMMdd/HH&quot;12345678900002.log&quot;" />
        <param name="maximumFileSize" value="200MB" />
        <param name="MaxSizeRollBackups" value="5" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>
    <logger name="12345678900003" additivity="false">
        <level value="ALL" />
        <appender-ref ref="12345678900003" />
    </logger>
    <appender name="12345678900003" type="log4net.Appender.RollingFileAppender">
        <param name="File" value="logs\Charger\" />
        <param name="AppendToFile" value="true" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <Encoding value="UTF-8" />
        <param name="StaticLogFileName" value="false" />
        <param name="RollingStyle" value="Composite" />
        <param name="DatePattern" value="yyyyMMdd/HH&quot;12345678900003.log&quot;" />
        <param name="maximumFileSize" value="200MB" />
        <param name="MaxSizeRollBackups" value="5" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>
    <logger name="12345678900004" additivity="false">
        <level value="ALL" />
        <appender-ref ref="12345678900004" />
    </logger>
    <appender name="12345678900004" type="log4net.Appender.RollingFileAppender">
        <param name="File" value="logs\Charger\" />
        <param name="AppendToFile" value="true" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <Encoding value="UTF-8" />
        <param name="StaticLogFileName" value="false" />
        <param name="RollingStyle" value="Composite" />
        <param name="DatePattern" value="yyyyMMdd/HH&quot;12345678900004.log&quot;" />
        <param name="maximumFileSize" value="200MB" />
        <param name="MaxSizeRollBackups" value="5" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>
    <logger name="12345678900005" additivity="false">
        <level value="ALL" />
        <appender-ref ref="12345678900005" />
    </logger>
    <appender name="12345678900005" type="log4net.Appender.RollingFileAppender">
        <param name="File" value="logs\Charger\" />
        <param name="AppendToFile" value="true" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <Encoding value="UTF-8" />
        <param name="StaticLogFileName" value="false" />
        <param name="RollingStyle" value="Composite" />
        <param name="DatePattern" value="yyyyMMdd/HH&quot;12345678900005.log&quot;" />
        <param name="maximumFileSize" value="200MB" />
        <param name="MaxSizeRollBackups" value="5" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>
    <logger name="12345678900006" additivity="false">
        <level value="ALL" />
        <appender-ref ref="12345678900006" />
    </logger>
    <appender name="12345678900006" type="log4net.Appender.RollingFileAppender">
        <param name="File" value="logs\Charger\" />
        <param name="AppendToFile" value="true" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <Encoding value="UTF-8" />
        <param name="StaticLogFileName" value="false" />
        <param name="RollingStyle" value="Composite" />
        <param name="DatePattern" value="yyyyMMdd/HH&quot;12345678900006.log&quot;" />
        <param name="maximumFileSize" value="200MB" />
        <param name="MaxSizeRollBackups" value="5" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date %level %thread %logger - %message%newline" />
        </layout>
    </appender>

    <root>
        <level value="INFO" />
        <appender-ref ref="Console" />
        <appender-ref ref="RollingFile" />
    </root>
</log4net>
